{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordito.dev/conformance/schemas/skills.schema.json",
  "title": "Ordito v1.1 — スキル入出力契約（§7.4）",
  "description": "原子スキルの入力・出力の JSON Schema。v1.0 の4スキル（update-block / detect-stale / generate / validate）に加え、v1.1 で作成・構造編集系（create-page / add-block / remove-block / move-block / delete-page / edit-collection）と scaffold（init）を後方互換に追加。準拠スキルを独立に実装・差し替えできるよう機械可読化したもの。$defs/<skill>_input・<skill>_output をエントリポイントに使う。出力は core フィールドを必須とし、note/file 等の付加フィールドは許容する。書き込み系の出力は generated:false を必須とする（§5.4）。",

  "$defs": {
    "error_output": {
      "type": "object",
      "required": ["ok", "error"],
      "properties": {
        "ok": { "const": false },
        "error": { "type": "string" }
      },
      "description": "全スキル共通: 失敗時はこの形を JSON で返す（生のスタックトレースで落ちない）。"
    },

    "update_block_input": {
      "type": "object",
      "required": ["doc", "block_id", "patch"],
      "properties": {
        "doc": { "type": "string", "description": "ドキュメント id（論理パス）" },
        "block_id": { "type": "string", "description": "更新するブロック id（tabs 内も可, §3.3.3）" },
        "patch": { "type": "object", "description": "ブロックにマージする内容フィールド。id/type は不可（§3.4）" },
        "ir_dir": { "type": "string" },
        "dry_run": { "type": "boolean", "description": "true なら書き込まず before/after プレビューだけ返す" }
      }
    },
    "update_block_output": {
      "type": "object",
      "required": ["ok", "doc", "block_id", "changed", "generated"],
      "properties": {
        "ok": { "const": true },
        "doc": { "type": "string" },
        "block_id": { "type": "string" },
        "changed": { "type": "boolean" },
        "updated_at": { "type": ["string", "null"] },
        "generated": { "const": false, "description": "書き込みスキルは生成しない（§5.4）" },
        "dry_run": { "type": "boolean" },
        "before": {},
        "after": {},
        "file": { "type": "string" },
        "note": { "type": "string" }
      }
    },

    "detect_stale_input": {
      "type": "object",
      "properties": { "ir_dir": { "type": "string" } }
    },
    "detect_stale_output": {
      "type": "object",
      "required": ["ok", "total", "stale_count", "stale"],
      "properties": {
        "ok": { "const": true },
        "ir_dir": { "type": "string" },
        "total": { "type": "integer" },
        "stale_count": { "type": "integer" },
        "stale": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "updated_at", "generated_at"],
            "properties": {
              "id": { "type": "string" },
              "file": { "type": "string" },
              "updated_at": { "type": ["string", "null"] },
              "generated_at": { "type": ["string", "null"] }
            }
          }
        }
      }
    },

    "generate_input": {
      "type": "object",
      "required": ["collection", "out"],
      "properties": {
        "collection": { "type": "string" },
        "out": { "type": "string" },
        "ir_dir": { "type": "string" },
        "only": {
          "oneOf": [
            { "type": "array", "items": { "type": "string" } },
            { "const": "stale" }
          ],
          "description": "省略時は全ページ。id 配列で指定、または \"stale\" で未反映のみ（§3.4）"
        },
        "mode": { "enum": ["deterministic", "mixed", "ai"] },
        "ai_cache": { "type": "string" }
      }
    },
    "generate_output": {
      "type": "object",
      "required": ["ok", "trigger", "out", "generated", "generated_at"],
      "properties": {
        "ok": { "const": true },
        "trigger": { "const": "explicit", "description": "生成は明示トリガーのみ（§5.4）" },
        "mode": { "type": "string" },
        "out": { "type": "string" },
        "generated": { "type": "array", "items": { "type": "string" } },
        "generated_at": { "type": ["string", "null"] },
        "unknown_ids": { "type": "array", "items": { "type": "string" } },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": { "type": "string" },
              "via": { "type": "string" },
              "valid": { "type": "boolean" },
              "warnings": { "type": "integer" }
            }
          }
        },
        "note": { "type": "string" }
      }
    },

    "validate_input": {
      "type": "object",
      "properties": {
        "doc": { "type": "string" },
        "ir_dir": { "type": "string" },
        "out": { "type": "string" },
        "contract": { "type": "string" }
      }
    },
    "validate_output": {
      "type": "object",
      "required": ["ok", "checked", "results"],
      "properties": {
        "ok": { "type": "boolean" },
        "contract": { "type": "string" },
        "checked": { "type": "integer" },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "ir_schema", "fieldmap"],
            "properties": {
              "id": { "type": "string" },
              "file": { "type": "string" },
              "ir_schema": { "type": "object" },
              "fieldmap": { "type": "object" },
              "mechanical": { "type": "object" },
              "fidelity": { "type": "object" }
            }
          }
        }
      }
    },

    "create_page_input": {
      "type": "object",
      "required": ["doc", "title"],
      "properties": {
        "doc": { "type": "string", "description": "新規ページの論理パス id。\"index\" 不可（§3.6）" },
        "title": { "type": "string" },
        "blocks": { "type": "array", "description": "初期ブロック。id 無しは自動採番" },
        "meta": { "type": "object", "description": "order/tags/sources など。title/updated_at/generated_at は上書きされる" },
        "nav": { "type": "object", "description": "{ under?, order?, label? } 指定で同時にナビ掲載" },
        "ir_dir": { "type": "string" },
        "collection": { "type": "string" },
        "dry_run": { "type": "boolean" }
      }
    },
    "create_page_output": {
      "type": "object",
      "required": ["ok", "doc", "created", "in_nav", "generated"],
      "properties": {
        "ok": { "const": true },
        "doc": { "type": "string" },
        "created": { "type": "boolean" },
        "in_nav": { "type": "boolean" },
        "updated_at": { "type": ["string", "null"] },
        "generated": { "const": false, "description": "作成は生成しない（§5.4）" },
        "dry_run": { "type": "boolean" },
        "file": { "type": "string" },
        "note": { "type": "string" }
      }
    },

    "add_block_input": {
      "type": "object",
      "required": ["doc", "block"],
      "properties": {
        "doc": { "type": "string" },
        "block": { "type": "object", "description": "追加するブロック（type 必須）。id 無しは自動採番" },
        "position": { "type": "object", "description": "{ append?|at?|after?|before?, in_tab? }" },
        "ir_dir": { "type": "string" },
        "dry_run": { "type": "boolean" }
      }
    },
    "add_block_output": {
      "type": "object",
      "required": ["ok", "doc", "block_id", "added", "generated"],
      "properties": {
        "ok": { "const": true },
        "doc": { "type": "string" },
        "block_id": { "type": "string" },
        "added": { "type": "boolean" },
        "position": { "type": "object" },
        "updated_at": { "type": ["string", "null"] },
        "generated": { "const": false },
        "dry_run": { "type": "boolean" },
        "file": { "type": "string" },
        "note": { "type": "string" }
      }
    },

    "remove_block_input": {
      "type": "object",
      "required": ["doc", "block_id"],
      "properties": {
        "doc": { "type": "string" },
        "block_id": { "type": "string" },
        "ir_dir": { "type": "string" },
        "dry_run": { "type": "boolean" }
      }
    },
    "remove_block_output": {
      "type": "object",
      "required": ["ok", "doc", "block_id", "removed", "generated"],
      "properties": {
        "ok": { "const": true },
        "doc": { "type": "string" },
        "block_id": { "type": "string" },
        "removed": { "type": "boolean" },
        "before": {},
        "updated_at": { "type": ["string", "null"] },
        "generated": { "const": false },
        "dry_run": { "type": "boolean" },
        "file": { "type": "string" },
        "note": { "type": "string" }
      }
    },

    "move_block_input": {
      "type": "object",
      "required": ["doc", "block_id", "position"],
      "properties": {
        "doc": { "type": "string" },
        "block_id": { "type": "string" },
        "position": { "type": "object", "description": "{ at?|after?|before?, in_tab? }" },
        "ir_dir": { "type": "string" },
        "dry_run": { "type": "boolean" }
      }
    },
    "move_block_output": {
      "type": "object",
      "required": ["ok", "doc", "block_id", "moved", "generated"],
      "properties": {
        "ok": { "const": true },
        "doc": { "type": "string" },
        "block_id": { "type": "string" },
        "moved": { "type": "boolean" },
        "position": { "type": "object" },
        "updated_at": { "type": ["string", "null"] },
        "generated": { "const": false },
        "dry_run": { "type": "boolean" },
        "file": { "type": "string" },
        "note": { "type": "string" }
      }
    },

    "delete_page_input": {
      "type": "object",
      "required": ["doc"],
      "properties": {
        "doc": { "type": "string" },
        "prune_nav": { "type": "boolean", "description": "既定 true: コレクションからもナビ項目を除去" },
        "collection": { "type": "string" },
        "ir_dir": { "type": "string" },
        "dry_run": { "type": "boolean" }
      }
    },
    "delete_page_output": {
      "type": "object",
      "required": ["ok", "doc", "deleted", "removed_from_nav", "generated"],
      "properties": {
        "ok": { "const": true },
        "doc": { "type": "string" },
        "deleted": { "type": "boolean" },
        "removed_from_nav": { "type": "boolean" },
        "generated": { "const": false },
        "dry_run": { "type": "boolean" },
        "file": { "type": "string" },
        "note": { "type": "string" }
      }
    },

    "edit_collection_input": {
      "type": "object",
      "required": ["op"],
      "properties": {
        "op": { "enum": ["add", "move", "remove", "relabel", "set_order"] },
        "item": { "type": "object", "description": "add 用: { doc, label? } か { group, items? }" },
        "doc": { "type": "string" },
        "group": { "type": "string" },
        "under": { "type": "array", "items": { "type": "string" }, "description": "グループ名パス" },
        "order": { "type": "number" },
        "label": { "type": "string" },
        "collection": { "type": "string" },
        "dry_run": { "type": "boolean" }
      }
    },
    "edit_collection_output": {
      "type": "object",
      "required": ["ok", "op", "collection_id", "changed", "generated"],
      "properties": {
        "ok": { "const": true },
        "op": { "type": "string" },
        "collection_id": { "type": "string" },
        "changed": { "type": "boolean" },
        "generated": { "const": false },
        "dry_run": { "type": "boolean" },
        "file": { "type": "string" },
        "note": { "type": "string" }
      }
    },

    "init_input": {
      "type": "object",
      "properties": {
        "root": { "type": "string" },
        "ir_dir": { "type": "string" },
        "out": { "type": "string" },
        "collection": { "type": "string" },
        "template_id": { "type": "string" },
        "mode": { "enum": ["deterministic", "mixed", "ai"] },
        "title": { "type": "string" },
        "starter_page": { "type": "boolean" },
        "workflow": { "type": "boolean" },
        "force": { "type": "boolean" }
      }
    },
    "init_output": {
      "type": "object",
      "required": ["ok", "root", "created", "skipped", "generated"],
      "properties": {
        "ok": { "const": true },
        "root": { "type": "string" },
        "created": { "type": "array", "items": { "type": "string" } },
        "skipped": { "type": "array", "items": { "type": "string" } },
        "next_steps": { "type": "array", "items": { "type": "string" } },
        "generated": { "const": false },
        "note": { "type": "string" }
      }
    }
  }
}
