{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordito.dev/conformance/schemas/ordito.schema.json",
  "title": "Ordito v1.0 — IR ドキュメント / ブロック語彙 / コレクション",
  "description": "各ブロック型のフィールドスキーマとコレクションの詳細スキーマを機械可読化した、v1.0 の準拠テスト用スキーマ。$defs/document・$defs/collection・$defs/block をエントリポイントとして使う。",

  "$defs": {
    "document": {
      "type": "object",
      "required": ["id", "meta", "blocks"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "description": "ドキュメントの一意な論理パス（§3.2）" },
        "meta": { "$ref": "#/$defs/meta" },
        "blocks": { "type": "array", "items": { "$ref": "#/$defs/block" } }
      }
    },

    "meta": {
      "type": "object",
      "required": ["title"],
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string" },
        "order": { "type": "number" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "updated_at": { "type": "string" },
        "generated_at": { "type": ["string", "null"] },
        "sources": { "type": "array", "items": { "type": "object" } }
      }
    },

    "block": {
      "type": "object",
      "description": "id/type は各 oneOf 分岐が required で持つ（二重定義を避けここでは課さない）",
      "oneOf": [
        { "$ref": "#/$defs/blocks/heading" },
        { "$ref": "#/$defs/blocks/paragraph" },
        { "$ref": "#/$defs/blocks/code" },
        { "$ref": "#/$defs/blocks/params" },
        { "$ref": "#/$defs/blocks/table" },
        { "$ref": "#/$defs/blocks/note" },
        { "$ref": "#/$defs/blocks/list" },
        { "$ref": "#/$defs/blocks/link" },
        { "$ref": "#/$defs/blocks/tabs" },
        { "$ref": "#/$defs/blocks/steps" }
      ]
    },

    "blocks": {
      "heading": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "type", "level", "text"],
        "properties": {
          "id": { "type": "string" }, "type": { "const": "heading" },
          "level": { "type": "integer", "minimum": 1, "maximum": 6 },
          "text": { "type": "string" }
        }
      },
      "paragraph": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "type", "text"],
        "properties": {
          "id": { "type": "string" }, "type": { "const": "paragraph" },
          "text": { "type": "string", "description": "インライン記法可（§3.3.1）" }
        }
      },
      "code": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "type", "lang", "text"],
        "properties": {
          "id": { "type": "string" }, "type": { "const": "code" },
          "lang": { "type": "string" }, "text": { "type": "string" },
          "filename": { "type": "string" }
        }
      },
      "params": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "type", "items"],
        "properties": {
          "id": { "type": "string" }, "type": { "const": "params" },
          "items": { "type": "array", "items": { "$ref": "#/$defs/paramItem" } }
        }
      },
      "table": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "type", "headers", "rows"],
        "properties": {
          "id": { "type": "string" }, "type": { "const": "table" },
          "headers": { "type": "array", "items": { "type": "string" } },
          "rows": { "type": "array", "items": { "type": "array", "items": { "type": "string" } } }
        }
      },
      "note": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "type", "variant", "text"],
        "properties": {
          "id": { "type": "string" }, "type": { "const": "note" },
          "variant": { "enum": ["info", "warning", "danger"] },
          "text": { "type": "string" }
        }
      },
      "list": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "type", "ordered", "items"],
        "properties": {
          "id": { "type": "string" }, "type": { "const": "list" },
          "ordered": { "type": "boolean" },
          "items": { "type": "array", "items": { "type": "string" } }
        }
      },
      "link": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "type", "href", "text"],
        "properties": {
          "id": { "type": "string" }, "type": { "const": "link" },
          "href": { "type": "string", "description": "内部参照(doc id) または外部URL（§3.3.2）" },
          "text": { "type": "string" }
        }
      },
      "tabs": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "type", "tabs"],
        "properties": {
          "id": { "type": "string" }, "type": { "const": "tabs" },
          "tabs": {
            "type": "array",
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["label", "blocks"],
              "properties": {
                "label": { "type": "string" },
                "blocks": { "type": "array", "items": { "$ref": "#/$defs/block" }, "description": "ブロックの再帰（§3.3.3）" }
              }
            }
          }
        }
      },
      "steps": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "type", "items"],
        "properties": {
          "id": { "type": "string" }, "type": { "const": "steps" },
          "items": { "type": "array", "items": { "$ref": "#/$defs/stepItem" } }
        }
      }
    },

    "paramItem": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "type", "required", "desc"],
      "properties": {
        "name": { "type": "string" }, "type": { "type": "string" },
        "required": { "type": "boolean" }, "desc": { "type": "string" },
        "default": { "type": ["string", "number", "boolean", "null"], "description": "既定値（型は任意。未設定は null）" }
      }
    },

    "stepItem": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object", "additionalProperties": false,
          "required": ["text"],
          "properties": { "title": { "type": "string" }, "text": { "type": "string" } }
        }
      ]
    },

    "collection": {
      "type": "object",
      "required": ["collection_id", "title", "nav"],
      "additionalProperties": false,
      "properties": {
        "collection_id": { "type": "string" },
        "title": { "type": "string" },
        "nav": { "type": "array", "items": { "$ref": "#/$defs/navItem" } }
      }
    },

    "navItem": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["doc"],
          "properties": {
            "doc": { "type": "string", "description": "ドキュメント id（論理パス）。実在性はスキーマでは検証せず、生成時に未解決参照として警告する（§3.3.2/§6.1）" },
            "order": { "type": "number" },
            "label": { "type": "string", "description": "ナビ表示名の上書き（省略時は meta.title）" }
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["group", "items"],
          "properties": {
            "group": { "type": "string", "description": "グループ見出し" },
            "order": { "type": "number" },
            "items": { "type": "array", "items": { "$ref": "#/$defs/navItem" }, "description": "多階層グループの再帰" }
          }
        }
      ]
    }
  }
}
